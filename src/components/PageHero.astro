---
const { label, title, text } = Astro.props;
---

<section class="bg-linen">
  <div class="container-pad py-20 lg:py-28">
    <p class="eyebrow">{label}</p>
    <h1 class="serif-title mt-5 max-w-4xl text-6xl sm:text-7xl">{title}</h1>
    {text && <p class="mt-7 max-w-2xl text-lg leading-8 text-jungle/68">{text}</p>}
  </div>
</section>
