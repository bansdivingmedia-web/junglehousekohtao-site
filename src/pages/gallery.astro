---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { gallery } from "../data/gallery";
import { siteSettings } from "../data/siteSettings";
---

<BaseLayout title={`Gallery | ${siteSettings.resortName}`}>
  <main>
    <PageHero label="Gallery" title="A Quiet Look Around" text={`Pool light, garden paths, hillside views and the calm corners that shape a stay at ${siteSettings.resortName}.`} />
    <section class="container-pad grid gap-6 py-20 md:grid-cols-2 lg:grid-cols-3">
      {gallery.map((item, index) => (
        <figure class={`${index === 0 ? "lg:col-span-2" : ""} overflow-hidden rounded-[1.75rem] bg-linen shadow-soft`}>
          <img class="aspect-[4/3] w-full object-cover" src={item.image} alt={item.alt} />
          <figcaption class="flex items-center justify-between p-5">
            <span class="font-serif text-2xl font-semibold">{item.title}</span>
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-moss">{item.category}</span>
          </figcaption>
        </figure>
      ))}
    </section>
  </main>
</BaseLayout>
