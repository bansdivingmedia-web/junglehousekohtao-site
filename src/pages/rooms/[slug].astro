---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { rooms } from "../../data/rooms";
import { siteSettings } from "../../data/siteSettings";
import { BedDouble, BedSingle, CalendarDays, ChevronLeft, Sparkles, Users, Waves } from "lucide-astro";

export function getStaticPaths() {
  return rooms.filter((room) => room.category !== "Cozy Poolside").map((room) => ({
    params: { slug: room.slug },
    props: { room },
  }));
}

const { room } = Astro.props;
const relatedRooms = rooms.filter((item) => item.slug !== room.slug && item.category === room.category).slice(0, 2);
const gallery = room.gallery?.length ? room.gallery : [room.mainImage];
---

<BaseLayout title={`${room.title} | ${siteSettings.resortName}`} description={room.shortDescription}>
  <main>
    <section class="relative overflow-hidden bg-[#f8f3ea] text-jungle">
      <div class="absolute inset-0">
        <img class="h-full w-full object-cover opacity-55" src={room.mainImage} alt={`${room.title} at ${siteSettings.resortName}`} />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(248,243,234,0.96),rgba(248,243,234,0.78),rgba(248,243,234,0.22))]"></div>
      </div>
      <div class="container-pad relative grid min-h-[520px] items-end pb-14 pt-32">
        <div class="max-w-3xl">
          <a class="mb-8 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.16em] text-jungle/70" href="/rooms">
            <ChevronLeft size={15} /> Back to Stay
          </a>
          <p class="eyebrow">{room.category}</p>
          <h1 class="mt-4 font-serif text-5xl font-semibold leading-none sm:text-7xl">{room.title}</h1>
          <p class="mt-7 max-w-2xl text-lg leading-9 text-jungle/70">{room.longDescription}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="rounded-full border border-jungle/10 bg-[#fffdf8] px-5 py-3 text-xs font-bold uppercase tracking-[0.16em]">{room.bedType}</span>
            <span class="rounded-full border border-jungle/10 bg-[#fffdf8] px-5 py-3 text-xs font-bold uppercase tracking-[0.16em]">{room.viewType}</span>
            {room.status === "Mockup" && <span class="rounded-full border border-gold/40 bg-gold/20 px-5 py-3 text-xs font-bold uppercase tracking-[0.16em]">Mockup Design</span>}
          </div>
        </div>
      </div>
    </section>

    <section class="container-pad grid gap-12 py-16 lg:grid-cols-[1.1fr_0.75fr] lg:py-20">
      <div>
        <div class="grid gap-4">
          <img class="aspect-[1.55/1] w-full rounded-lg object-cover shadow-soft" src={gallery[0]} alt={`${room.title} main room view`} />
          <div class="grid gap-4 sm:grid-cols-3">
            {gallery.slice(1, 4).map((image) => (
              <img class="aspect-[1.35/1] rounded-lg object-cover shadow-[0_10px_24px_rgba(17,16,15,0.08)]" src={image} alt={`${room.title} gallery preview`} />
            ))}
          </div>
        </div>
      </div>

      <aside class="premium-panel h-fit rounded-lg border border-jungle/10 bg-[#fffdf8] p-7 shadow-[0_12px_32px_rgba(17,16,15,0.08)]">
        <p class="eyebrow">Room Details</p>
        <p class="mt-5 text-sm text-jungle/58">{room.status === "Mockup" ? "Status" : "From"} <span class="font-serif text-4xl font-semibold text-jungle">{room.priceFrom}</span></p>
        <div class="mt-7 grid gap-4 text-sm text-jungle/72">
          <span class="inline-flex items-center gap-3"><Users size={17} />{room.guests}</span>
          <span class="inline-flex items-center gap-3">{room.bedType.includes("Twin") ? <BedSingle size={17} /> : <BedDouble size={17} />}{room.bedType}</span>
          <span class="inline-flex items-center gap-3"><Waves size={17} />{room.viewType}</span>
        </div>
        <div class="mt-8 border-t border-jungle/10 pt-7">
          <p class="mb-4 text-[11px] font-bold uppercase tracking-[0.18em] text-jungle/55">Amenities</p>
          <ul class="grid gap-3 text-sm text-jungle/72">
            {room.amenities.map((amenity) => <li class="inline-flex items-center gap-2"><Sparkles size={14} class="text-gold" />{amenity}</li>)}
          </ul>
        </div>
        <a class="button-primary mt-8 w-full gap-3" href="/#booking">
          <CalendarDays size={16} /> Request Availability
        </a>
      </aside>
    </section>

    {relatedRooms.length > 0 && (
      <section class="container-pad pb-20">
        <div class="mb-7 flex items-center justify-between gap-4">
          <div>
            <p class="eyebrow">Same Category</p>
            <h2 class="serif-title mt-2 text-4xl">More {room.category}</h2>
          </div>
          <a class="button-outline" href="/rooms">All Rooms</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {relatedRooms.map((item) => (
            <a class="premium-card overflow-hidden rounded-lg border border-jungle/12 bg-[#fffdf8] shadow-[0_12px_28px_rgba(17,16,15,0.08)]" href={`/rooms/${item.slug}/`}>
              <img class="aspect-[1.7/1] w-full object-cover" src={item.mainImage} alt={`${item.title} accommodation`} />
              <div class="p-6">
                <p class="eyebrow">{item.bedType}</p>
                <h3 class="mt-2 font-serif text-3xl font-semibold">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-jungle/68">{item.shortDescription}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
