---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteSettings } from "../data/siteSettings";
---

<BaseLayout title={`Contact | ${siteSettings.resortName}`}>
  <main>
    <PageHero label="Contact" title="Begin Your Stay" text="Reach out for availability, island transfers, room details or anything you would like arranged before arrival." />
    <section class="container-pad grid gap-10 py-20 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[1.75rem] bg-jungle p-9 text-cream shadow-soft">
        <h2 class="font-serif text-4xl font-semibold">{siteSettings.resortName}</h2>
        <div class="mt-8 grid gap-5 text-cream/75">
          <p>{siteSettings.address}</p>
          <a href={`tel:${siteSettings.phone}`}>{siteSettings.phone}</a>
          <a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a>
          <a href={siteSettings.whatsappUrl}>WhatsApp</a>
          <a href={siteSettings.googleMapUrl}>Open map</a>
        </div>
      </div>
      <form class="grid gap-4 rounded-[1.75rem] bg-linen p-7 shadow-soft">
        <div class="grid gap-4 md:grid-cols-2">
          <input class="rounded-full border border-jungle/10 bg-white/70 px-5 py-4 outline-none focus:border-jungle" placeholder="Name" />
          <input class="rounded-full border border-jungle/10 bg-white/70 px-5 py-4 outline-none focus:border-jungle" placeholder="Email" type="email" />
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <input class="rounded-full border border-jungle/10 bg-white/70 px-5 py-4 outline-none focus:border-jungle" placeholder="Arrival" />
          <input class="rounded-full border border-jungle/10 bg-white/70 px-5 py-4 outline-none focus:border-jungle" placeholder="Departure" />
        </div>
        <textarea class="min-h-40 rounded-[1.5rem] border border-jungle/10 bg-white/70 px-5 py-4 outline-none focus:border-jungle" placeholder="Message"></textarea>
        <a class="button-primary w-fit" href={siteSettings.bookNowUrl}>Book Now</a>
      </form>
    </section>
  </main>
</BaseLayout>
