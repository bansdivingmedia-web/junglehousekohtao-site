---
import { siteSettings } from "../data/siteSettings";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Reset Password | {siteSettings.resortName}</title>
    <style>
      :root {
        color: #11100f;
        background: #fbf8ef;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          linear-gradient(90deg, rgba(7, 20, 15, 0.8), rgba(7, 20, 15, 0.26)),
          url("/images/resort-hero.jpg") center / cover;
      }

      main {
        width: min(100%, 430px);
        border: 1px solid rgba(23, 63, 46, 0.14);
        border-radius: 8px;
        background: #fffdf8;
        box-shadow: 0 22px 60px rgba(6, 24, 17, 0.24);
        padding: 32px;
      }

      img {
        height: 70px;
        width: auto;
        display: block;
        margin-bottom: 22px;
      }

      h1 {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 34px;
        line-height: 1.05;
        font-weight: 500;
      }

      p {
        margin: 14px 0 0;
        color: rgba(17, 16, 15, 0.72);
        line-height: 1.7;
      }

      form {
        display: grid;
        gap: 14px;
        margin-top: 26px;
      }

      label {
        display: grid;
        gap: 8px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      input {
        width: 100%;
        border: 1px solid rgba(17, 16, 15, 0.22);
        border-radius: 4px;
        background: #fbf8ef;
        color: #11100f;
        font: inherit;
        font-size: 16px;
        padding: 14px 15px;
        outline: none;
      }

      input:focus {
        border-color: #11100f;
        box-shadow: 0 0 0 3px rgba(17, 16, 15, 0.12);
      }

      button,
      .button {
        border: 0;
        border-radius: 4px;
        background: #11100f;
        color: #fffaf0;
        cursor: pointer;
        font: inherit;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.1em;
        padding: 15px 18px;
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
      }

      button:disabled {
        cursor: wait;
        opacity: 0.62;
      }

      .message {
        min-height: 28px;
        border-radius: 4px;
        margin-top: 18px;
        padding: 0;
        font-weight: 700;
      }

      .message[data-tone="error"] {
        color: #8b2f20;
      }

      .message[data-tone="success"] {
        color: #11100f;
      }

      .hidden {
        display: none;
      }
    </style>
  </head>
  <body>
    <main>
      <img src="/images/brand/cozy-logo-small.png" alt={siteSettings.resortName} />
      <h1 id="title">Reset your password</h1>
      <p id="intro">Enter a new password for your COZY Koh Tao admin account.</p>

      <form id="password-form">
        <label>
          New password
          <input id="password" type="password" autocomplete="new-password" minlength="6" required />
        </label>
        <label>
          Confirm password
          <input id="confirm-password" type="password" autocomplete="new-password" minlength="6" required />
        </label>
        <button id="submit-button" type="submit">Set Password</button>
      </form>

      <form id="email-form" class="hidden">
        <label>
          Email address
          <input id="email" type="email" autocomplete="email" value="bansdivingmedia@gmail.com" required />
        </label>
        <button id="email-button" type="submit">Send Reset Email</button>
      </form>

      <p id="message" class="message" aria-live="polite"></p>
      <a id="admin-link" class="button hidden" href="/admin/">Open Admin</a>
    </main>

    <script is:inline>
      const apiBase = "/.netlify/identity";
      const hash = new URLSearchParams(window.location.hash.replace(/^#\/?/, ""));
      const recoveryToken = hash.get("recovery_token");
      const inviteToken = hash.get("invite_token");
      const confirmationToken = hash.get("confirmation_token");
      const passwordForm = document.querySelector("#password-form");
      const emailForm = document.querySelector("#email-form");
      const passwordInput = document.querySelector("#password");
      const confirmPasswordInput = document.querySelector("#confirm-password");
      const emailInput = document.querySelector("#email");
      const submitButton = document.querySelector("#submit-button");
      const emailButton = document.querySelector("#email-button");
      const title = document.querySelector("#title");
      const intro = document.querySelector("#intro");
      const message = document.querySelector("#message");
      const adminLink = document.querySelector("#admin-link");

      const setMessage = (text, tone = "error") => {
        message.textContent = text;
        message.dataset.tone = tone;
      };

      const requestJson = async (path, options) => {
        const response = await fetch(`${apiBase}${path}`, {
          ...options,
          headers: {
            "Content-Type": "application/json",
            ...(options.headers || {}),
          },
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(data.msg || data.error_description || "Something went wrong.");
        }
        return data;
      };

      const showEmailRecovery = () => {
        title.textContent = "Forgot password";
        intro.textContent = "Enter your admin email and Netlify will send a fresh reset link.";
        passwordForm.classList.add("hidden");
        emailForm.classList.remove("hidden");
      };

      const clearHash = () => {
        window.history.replaceState(null, "", window.location.pathname);
      };

      if (confirmationToken) {
        title.textContent = "Confirming email";
        intro.textContent = "Please wait while we confirm your account.";
        passwordForm.classList.add("hidden");
        requestJson("/verify", {
          method: "POST",
          body: JSON.stringify({ token: confirmationToken, type: "signup" }),
        })
          .then(() => {
            clearHash();
            setMessage("Email confirmed. You can now log in to the admin.", "success");
            adminLink.classList.remove("hidden");
          })
          .catch((error) => {
            setMessage(error.message);
            showEmailRecovery();
          });
      } else if (!recoveryToken && !inviteToken) {
        showEmailRecovery();
      } else if (inviteToken) {
        title.textContent = "Create your admin password";
        intro.textContent = "Set a password to accept the admin invitation.";
      }

      passwordForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const password = passwordInput.value;
        const confirmPassword = confirmPasswordInput.value;
        if (password !== confirmPassword) {
          setMessage("Passwords do not match.");
          return;
        }

        submitButton.disabled = true;
        setMessage("Setting password...", "success");

        try {
          if (inviteToken) {
            await requestJson("/verify", {
              method: "POST",
              body: JSON.stringify({ token: inviteToken, password, type: "signup" }),
            });
          } else {
            const tokenResponse = await requestJson("/verify", {
              method: "POST",
              body: JSON.stringify({ token: recoveryToken, type: "recovery" }),
            });
            const accessToken = tokenResponse.access_token || tokenResponse.token?.access_token;
            if (!accessToken) throw new Error("Reset link could not be verified.");
            await requestJson("/user", {
              method: "PUT",
              headers: { Authorization: `Bearer ${accessToken}` },
              body: JSON.stringify({ password }),
            });
          }

          clearHash();
          passwordForm.classList.add("hidden");
          adminLink.classList.remove("hidden");
          setMessage("Password updated. You can open the admin now.", "success");
        } catch (error) {
          setMessage(error.message.includes("not found") ? "This reset link is expired. Send a new reset email below." : error.message);
          showEmailRecovery();
        } finally {
          submitButton.disabled = false;
        }
      });

      emailForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        emailButton.disabled = true;
        setMessage("Sending reset email...", "success");

        try {
          await requestJson("/recover", {
            method: "POST",
            body: JSON.stringify({ email: emailInput.value }),
          });
          setMessage("Reset email sent. Open the newest email link to set your password.", "success");
        } catch (error) {
          setMessage(error.message);
        } finally {
          emailButton.disabled = false;
        }
      });
    </script>
  </body>
</html>
