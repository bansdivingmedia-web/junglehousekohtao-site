---
import { siteSettings } from "../data/siteSettings";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Logout | {siteSettings.resortName}</title>
    <style>
      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        background: #fbf8ef;
        color: #11100f;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      main {
        width: min(100%, 420px);
        padding: 32px;
        text-align: center;
      }

      img {
        height: 78px;
        width: auto;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 34px;
        font-weight: 500;
      }

      p {
        color: rgba(17, 16, 15, 0.72);
        line-height: 1.7;
      }

      a {
        display: inline-block;
        margin-top: 16px;
        border-radius: 4px;
        background: #11100f;
        color: #fffaf0;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.1em;
        padding: 14px 18px;
        text-decoration: none;
        text-transform: uppercase;
      }
    </style>
  </head>
  <body>
    <main>
      <img src="/images/brand/cozy-logo-small.png" alt={siteSettings.resortName} />
      <h1>Logging out</h1>
      <p id="message">Please wait while we sign you out.</p>
      <a href="/" class="hidden">Back to Website</a>
    </main>

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      const message = document.querySelector("#message");
      const homeLink = document.querySelector("a");

      const finishLogout = () => {
        localStorage.removeItem("gotrue.user");
        sessionStorage.clear();
        document.cookie = "nf_jwt=; Max-Age=0; path=/";
        message.textContent = "You are logged out.";
        homeLink.classList.remove("hidden");
        window.setTimeout(() => {
          window.location.href = "/";
        }, 700);
      };

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", () => {
          const user = window.netlifyIdentity.currentUser();
          if (user) {
            window.netlifyIdentity.logout();
          } else {
            finishLogout();
          }
        });
        window.netlifyIdentity.on("logout", finishLogout);
        window.netlifyIdentity.init();
      } else {
        finishLogout();
      }
    </script>
  </body>
</html>
