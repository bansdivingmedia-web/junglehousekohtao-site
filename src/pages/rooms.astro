---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { rooms } from "../data/rooms";
import { siteSettings } from "../data/siteSettings";
---

<BaseLayout title={`Rooms | ${siteSettings.resortName}`}>
  <main>
    <PageHero label="Stay" title="Rooms Made for Rest" text="Choose a garden bungalow, pool view room or private villa, each shaped by natural texture, soft light and tropical quiet." />
    <section class="container-pad grid gap-8 py-20 lg:grid-cols-3">
      {rooms.map((room) => (
        <article class="overflow-hidden rounded-[1.75rem] bg-linen shadow-soft">
          <img class="aspect-[4/3] w-full object-cover" src={room.mainImage} alt={`${room.title} accommodation`} />
          <div class="p-7">
            <h2 class="font-serif text-3xl font-semibold">{room.title}</h2>
            <p class="mt-4 leading-7 text-jungle/68">{room.longDescription}</p>
            <div class="mt-6 flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-moss">
              <span>{room.guests}</span><span>•</span><span>{room.viewType}</span>
            </div>
            <ul class="mt-6 grid gap-2 text-sm text-jungle/70">
              {room.amenities.map((amenity) => <li>• {amenity}</li>)}
            </ul>
            <div class="mt-7 flex items-center justify-between gap-4">
              <p class="text-sm text-jungle/58">From <span class="font-serif text-3xl font-semibold text-jungle">{room.priceFrom}</span></p>
              <a class="button-primary" href={room.bookingUrl}>Book</a>
            </div>
          </div>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
